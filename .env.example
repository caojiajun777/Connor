# Copy to repo root as `.env` (gitignored) or set as User environment variables.
# Required for public site + tunnel launch.

# --- Public site ---
CONNOR_PUBLIC_SITE_URL=https://YOUR_DOMAIN
CONNOR_PUBLIC_API_BASE=http://127.0.0.1:8080
CONNOR_MEDIA_PUBLIC_BASE_URL=/media
CONNOR_OPS_API_KEY=replace-with-long-random-secret
# Optional local-only escape hatch (never set on the tunnel host):
# CONNOR_ALLOW_INSECURE_LOCAL=1

# --- Backend (already used by daily collect/publish) ---
# CONNOR_DATABASE_URL=postgresql+psycopg://...
# CONNOR_REDIS_URL=redis://127.0.0.1:6379/0
# CONNOR_LLM_API_KEY=
# DEEPSEEK_API_KEY=

# Optional
# CONNOR_CORS_ORIGINS=https://YOUR_DOMAIN
# CONNOR_PUBLIC_API_TIMEOUT_MS=12000
# Drop owner / office traffic from public analytics (comma-separated IPs or CIDRs).
# Example: CONNOR_ANALYTICS_EXCLUDE_IPS=203.0.113.10,198.51.100.0/24
# CONNOR_ANALYTICS_EXCLUDE_IPS=
# Optional: also drop known browser visitor_ids (from localStorage connor_vid)
# CONNOR_ANALYTICS_EXCLUDE_VISITOR_IDS=
# Daily publish window (Asia/Shanghai). Pipeline defaults to 08:00; site copy says 12:00.
# CONNOR_SCHEDULE_HOUR=8
# CONNOR_SCHEDULE_MINUTE=0
# CONNOR_SCHEDULE_TZ=Asia/Shanghai
# CONNOR_SCHEDULE_ENABLED=1

# --- X collect (MCP / Chrome profile) ---
# Fail-forward defaults: short pauses, no long MCP/backoff loops.
# After main collect, auto-retry failures every 15m while worth-retry count > 5.
# CONNOR_COLLECT_AUTO_RETRY=1
# CONNOR_COLLECT_RETRY_INTERVAL_SEC=600
# CONNOR_COLLECT_RETRY_STOP_BELOW=5
# CONNOR_COLLECT_RETRY_MAX_PASSES=0
# Publish deadline (Asia/Shanghai): stop collect retry ~90m before noon so write/publish finishes by 12:00.
# CONNOR_PUBLISH_DEADLINE_HOUR=12
# CONNOR_PUBLISH_DEADLINE_MINUTE=0
# CONNOR_PUBLISH_DEADLINE_RESERVE_MIN=90
# Manual/supervisor: python scripts/auto_retry_failed_collect.py --run-id <id> --wait-for-collect-end
# Worth retry: x_service_error / rate_limit / mcp_empty_posts / timeouts
# Skip retry: auth/session / permanent browser errors; also stop when <= STOP_BELOW leftovers
# X_AGENT_PROFILE_DIR=C:\Users\90556\.codex-x-news-agent
# X_AGENT_TIMEOUT_MS=30000
# X_AGENT_MAX_CONCURRENT_PAGES=1
# CONNOR_EMPTY_POSTS_MAX_RETRIES=1
# CONNOR_COLLECT_ACCOUNT_PAUSE_MS=1000
# CONNOR_MCP_RATE_LIMIT_RETRIES=0
# CONNOR_COLLECT_REPORT_DATE=2026-07-23
# Optional: skip noisy source types this run (comma-separated)
# CONNOR_COLLECT_DEFER_SOURCE_TYPES=employee

# --- Short video (optional P1 TTS) ---
# pip install "connor[short_video]"  or: pip install edge-tts
# CONNOR_SHORT_VIDEO_VOICE=zh-CN-YunyangNeural
