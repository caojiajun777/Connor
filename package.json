{
  "name": "x-news-mcp-server",
  "version": "1.0.0",
  "description": "Local MCP server for read-only X news search using a persistent Chrome profile",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "login": "node dist/login.js",
    "test": "node --test dist/tests/*.test.js",
    "check": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "playwright-core": "1.61.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "typescript": "5.9.2"
  }
}
